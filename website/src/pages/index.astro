---
/**
 * Homepage v4 — "Orange Editorial Utility" rebuild.
 * Conversion page + router between urgent repair and planned install.
 * Rhythm: photo hero → routing junction → symptom navigator →
 * orange stat band → verified proof → real work → work-order pricing →
 * brand rail → towns → orange closing zone.
 * Repair stays dominant by design; installation is the quiet path.
 */
import SiteLayout from "../layouts/SiteLayout.astro";
import TrackHero from "../components/home/TrackHero.astro";
import RouteJunction from "../components/home/RouteJunction.astro";
import SymptomNavigator from "../components/home/SymptomNavigator.astro";
import StatBand from "../components/home/StatBand.astro";
import ProofBand from "../components/ProofBand.astro";
import RealWorkFeature from "../components/home/RealWorkFeature.astro";
import WorkOrder from "../components/home/WorkOrder.astro";
import ContinuousBrandRail from "../components/ContinuousBrandRail.astro";
import CityGrid from "../components/CityGrid.astro";
import CTASection from "../components/CTASection.astro";
---

<SiteLayout
  title="EZ Garage Doors | Garage Door Repair in Connecticut — Springs, Openers, Stuck Doors"
  description="Garage door won't close? EZ Garage Doors fixes stuck doors, broken springs, opener issues, cables, and off-track doors across Connecticut — written quote before work begins."
>
  <TrackHero />

  <RouteJunction />

  <SymptomNavigator />

  <StatBand />

  <ProofBand />

  <RealWorkFeature />

  <WorkOrder />

  <ContinuousBrandRail />

  <CityGrid compact />

  <CTASection
    variant="orange"
    heading="Door acting up today?"
    sub="Call EZ Garage Doors for repair service — written quote before work begins."
    callLabel="Call for Repair Service"
    note="Clear answer. Written quote. No pressure."
  />
</SiteLayout>
