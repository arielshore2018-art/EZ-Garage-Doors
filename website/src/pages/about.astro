---
/**
 * About page — identity and operating principles. No invented founder
 * story, no fake team bios, no stock "our values" filler. States what
 * is verified: 15 years, local CT, how the company works.
 */
import SiteLayout from "../layouts/SiteLayout.astro";
import ServiceHero from "../components/ServiceHero.astro";
import ProofColumns from "../components/home/ProofColumns.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ReviewProof from "../components/ReviewProof.astro";
import CityGrid from "../components/CityGrid.astro";
import CTASection from "../components/CTASection.astro";
import { APPROVED_CLAIMS, BUSINESS } from "../config/business";

import vanFront from "../assets/photos/ez-garage-door-service-van-front.jpg";
---

<SiteLayout
  title="About EZ Garage Doors | Local Connecticut Garage Door Company"
  description="EZ Garage Doors is a local Connecticut garage door company with 15 years in business. Written quotes before work, no bait pricing, repair and installation expertise."
>
  <ServiceHero
    imageId="team-van"
    eyebrow="Fast. Reliable. Local."
    heading="About EZ Garage Doors"
    sub={`A local ${BUSINESS.state} garage door company. 15 years in business, built on written quotes and straight answers.`}
    callLabel="Call EZ Garage Doors"
    callTrack="about_call_click"
    secondaryLabel="Get a Written Estimate"
    secondaryHref="/contact/#request"
    micro="No pressure. One quote, in writing."
  />

  <ProofColumns />

  <section class="section">
    <div class="wrap wrap--narrow">
      <SectionHeading eyebrow="How we work" title="The rules we don't bend" />
      <dl class="about-rules">
        <div>
          <dt>The quote is in writing, first.</dt>
          <dd>
            Every repair and every installation starts with a written quote you approve before
            work begins. That's the whole policy — there's no version of it with asterisks.
          </dd>
        </div>
        <div>
          <dt>No bait pricing.</dt>
          <dd>
            We don't advertise teaser prices that triple at the door. If a number sounds too good
            on the phone — from anyone — ask for it in writing and watch what happens.
          </dd>
        </div>
        <div>
          <dt>Repair when repair is right.</dt>
          <dd>
            A broken spring on a healthy door is a repair, not a sales opportunity. We replace
            doors when replacement is genuinely the better math, and we show you that math.
          </dd>
        </div>
        <div>
          <dt>Local, and staying that way.</dt>
          <dd>
            {APPROVED_CLAIMS.local} — not a national call center reselling jobs to whoever
            answers. The person who quotes your door is from the team that fixes it.
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <ReviewProof />

  <CityGrid />

  <CTASection
    heading="Want to see how we quote?"
    sub="Call about your door or request a written estimate — judge us by the paperwork."
  />
</SiteLayout>

<style>
  .about-hero {
    background: linear-gradient(120deg, var(--ez-white) 55%, var(--ez-concrete) 100%);
    padding-block: var(--space-7);
    border-bottom: 1px solid var(--ez-border);
  }

  .about-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-7);
    align-items: center;
  }

  .about-hero__sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-top: var(--space-4);
  }

  .about-hero__media img {
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    width: 100%;
    height: auto;
  }

  .about-rules > div {
    padding-block: var(--space-5);
    border-bottom: 1px dashed var(--ez-border);
  }

  .about-rules dt {
    font-family: var(--font-display);
    font-weight: 750;
    font-size: var(--text-xl);
    color: var(--ez-charcoal);
    margin-bottom: var(--space-2);
    display: flex;
    align-items: center;
  }

  .about-rules dt::before {
    content: "";
    width: 1.1rem;
    height: 3px;
    border-radius: 2px;
    background: var(--speed-line-gradient);
    margin-right: var(--space-2);
  }

  .about-rules dd {
    margin: 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 62rem) {
    .about-hero__grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>
