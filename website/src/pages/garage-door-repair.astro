---
/**
 * Main repair page — expanded architecture: full-bleed hero, proof bar,
 * image-led symptoms, causes, process, brands, work gallery, reviews, FAQ.
 */
import SiteLayout from "../layouts/SiteLayout.astro";
import ServiceHero from "../components/ServiceHero.astro";
import ProofColumns from "../components/home/ProofColumns.astro";
import RepairIssueGrid from "../components/RepairIssueGrid.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import TrustLogoStrip from "../components/TrustLogoStrip.astro";
import WorkGallery from "../components/WorkGallery.astro";
import ReviewCards from "../components/home/ReviewCards.astro";
import FaqList from "../components/FaqList.astro";
import CityGrid from "../components/CityGrid.astro";
import CTASection from "../components/CTASection.astro";
import SectionHeading from "../components/SectionHeading.astro";

const issues = [
  { symptom: "Door won't open or close", meaning: "Often a spring, opener, or track problem — stop forcing it and have it diagnosed." },
  { symptom: "Loud bang from the garage", meaning: "The classic sign of a snapped torsion spring. The door will feel very heavy." },
  { symptom: "Door is off its track", meaning: "Rollers or cables have failed or slipped. Keep the door still until it's secured." },
  { symptom: "Grinding, squealing, or shaking", meaning: "Worn rollers, dry hinges, or a failing opener drive. Cheap to fix early." },
];

const service = {
  name: "Garage Door Repair",
  description: "Diagnosis and repair of residential garage doors: springs, cables, rollers, tracks, openers, and stuck doors.",
  url: "/garage-door-repair/",
};

const faqs = [
  { question: "How fast can you get to my door?", answer: "Call and tell us your town and what the door is doing — we dispatch locally across central Connecticut and confirm your arrival window on the phone before anyone drives out." },
  { question: "Do you charge to come out and look?", answer: "You get the diagnosis explained and the repair price in writing before any work begins — ask about the current service-visit policy when you call, and the quote you approve is the price you pay." },
  { question: "Can I use the door until you arrive?", answer: "If you heard a bang, the door is crooked, or it's off track — no. The door is heavier than it looks and under spring tension. Leave it where it is and keep people and cars clear." },
  { question: "Do you repair doors you didn't install?", answer: "Yes. We service most major door and opener brands regardless of who installed them — see the brands strip on this page." },
  { question: "Repair or replace — how do you decide?", answer: "By the math, in writing. One failed spring on a healthy door is a repair. Rotting panels plus repeated failures usually favor replacement — we show you both numbers and you choose." },
];
---

<SiteLayout
  title="Garage Door Repair in Connecticut | EZ Garage Doors"
  description="Garage door repair in Connecticut: springs, cables, rollers, tracks, openers, and stuck doors. Local company, written quote before work begins."
  service={service}
  faqs={faqs}
>
  <ServiceHero
    imageId="hero-problem-door"
    eyebrow="Connecticut Garage Door Repair"
    heading="Garage Door Repair in Connecticut"
    sub="Springs, cables, rollers, tracks, openers, and stuck doors — repaired by a local team built for fast response."
    callLabel="Call for Repair"
    callTrack="repair_call_click"
  />

  <ProofColumns />

  <RepairIssueGrid heading="What is your door doing?" issues={issues} alt />

  <section class="section">
    <div class="wrap wrap--narrow">
      <SectionHeading eyebrow="Why it happens" title="What usually causes it" />
      <p>
        Garage doors fail at their moving parts: springs lose cycles and snap, cables fray at
        the bottom brackets, rollers wear flat, and tracks bend when a door runs against
        resistance. Openers usually get the blame — but half of "opener problems" are really a
        door that's too heavy or binding. That's why we inspect the whole system before quoting.
      </p>
    </div>
  </section>

  <ProcessSteps
    heading="How a repair visit works"
    steps={[
      { title: "Inspect", detail: "We check springs, cables, rollers, tracks, and opener balance — not just the loud symptom." },
      { title: "Explain", detail: "You see what failed and why, in plain language." },
      { title: "Written quote", detail: "The full price on paper before any work." },
      { title: "Approval, then repair", detail: "Work starts only after you approve. Door tested through full travel before we leave." },
    ]}
  />

  <TrustLogoStrip variant="combined" />

  <WorkGallery
    heading="Repair work, up close"
    imageIds={["stuck-repair", "broken-spring", "new-springs"]}
  />

  <section class="section">
    <div class="wrap">
      <SectionHeading eyebrow="What customers say" title="Repairs, reviewed" />
      <ReviewCards limit={3} />
    </div>
  </section>

  <FaqList faqs={faqs} heading="Garage door repair questions" />

  <CityGrid compact />

  <CTASection
    heading="Door acting up today?"
    sub="Call EZ Garage Doors — get a written quote before work begins."
    callLabel="Call for Repair"
  />
</SiteLayout>
