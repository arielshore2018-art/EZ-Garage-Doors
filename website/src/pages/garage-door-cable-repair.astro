---
/**
 * Cable / roller / track repair — phone-first urgency landing page.
 * Stripped layout, short, no install upsell above the fold.
 */
import LandingLayout from "../layouts/LandingLayout.astro";
import CallButton from "../components/CallButton.astro";
import MicroTrustBar from "../components/MicroTrustBar.astro";
import { APPROVED_CLAIMS } from "../config/business";

const signs = [
  "Cable hanging loose or coiled on the floor",
  "Door lifts crooked or shudders on the way up",
  "One side higher than the other",
  "Grinding or scraping from the tracks",
  "Rollers popping or binding mid-travel",
  "Frayed cable strands near the bottom bracket",
];

const service = {
  name: "Garage Door Cable, Roller & Track Repair",
  description: "Snapped cables, worn rollers, and bent tracks repaired — door realigned and balanced with a written quote before work.",
  url: "/garage-door-cable-repair/",
};
---

<LandingLayout
  title="Garage Door Cable Repair in Connecticut | EZ Garage Doors"
  description="Cable came off, rollers worn, or tracks bent? EZ Garage Doors repairs cables, rollers, and tracks across Connecticut — written quote before work begins."
  callLabel="Call for Cable Repair"
  service={service}
>
  <section class="cable-hero">
    <div class="wrap cable-hero__inner">
      <h1>Garage Door Cable &amp; Track Repair</h1>
      <p class="cable-hero__sub">
        Cable came off the drum, rollers worn out, or the door pulling crooked? Stop running the
        opener and call — a loose cable gets worse with every cycle.
      </p>
      <div class="cable-hero__actions">
        <CallButton label="Call for Cable Repair" size="lg" track="cable_call_click" />
        <a href="/contact/#request" class="btn btn--inverse-outline btn--lg" data-track="photo_cta_click">
          Text a Photo of the Cable
        </a>
      </div>
      <p class="cable-hero__note">
        Not sure it's the cable? Send a photo — we'll tell you the next step.
      </p>
      <div class="cable-hero__trust">
        <MicroTrustBar
          tone="dark"
          items={[APPROVED_CLAIMS.years, APPROVED_CLAIMS.local, APPROVED_CLAIMS.writtenQuote]}
        />
      </div>
    </div>
  </section>

  <section class="cable-signs">
    <div class="wrap">
      <h2>What a failing cable or track looks like</h2>
      <span class="speed-rail" aria-hidden="true"></span>
      <ul class="cable-signs__grid">
        {
          signs.map((sign) => (
            <li>
              <span class="speed-tick" aria-hidden="true" />
              {sign}
            </li>
          ))
        }
      </ul>
      <p class="cable-signs__safety">
        <strong>Careful:</strong> cables are under the same tension as the springs. Don't pull,
        rewind, or unbolt anything — keep the door still until it's serviced.
      </p>
    </div>
  </section>

  <section class="cable-quote">
    <div class="wrap wrap--narrow">
      <h2>Written quote before the repair</h2>
      <span class="speed-rail" aria-hidden="true"></span>
      <p>
        We check the cables, drums, rollers, tracks, and the spring balance behind them — a cable
        that "just slipped" usually slipped for a reason. You get what failed, what it costs, and
        the price <strong>in writing before work begins</strong>.
      </p>
    </div>
  </section>

  <section class="cable-final">
    <div class="wrap cable-final__inner">
      <h2>Door pulling crooked right now?</h2>
      <p>Call EZ Garage Doors — fast local cable, roller, and track repair.</p>
      <CallButton label="Call for Cable Repair" size="lg" track="cable_call_click" />
    </div>
  </section>
</LandingLayout>

<style>
  .cable-hero {
    background: var(--ez-charcoal);
    color: #c3ccd6;
    padding-block: var(--space-7);
    border-bottom: 4px solid var(--ez-orange);
  }

  .cable-hero h1 {
    color: #fff;
    max-width: 40rem;
  }

  .cable-hero__sub {
    font-size: var(--text-lg);
    margin-top: var(--space-4);
    max-width: 38rem;
    color: #b8c1cc;
  }

  .cable-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  .cable-hero__note {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: #8d98a5;
  }

  .cable-hero__trust {
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid rgb(255 255 255 / 0.15);
  }

  .cable-signs {
    padding-block: var(--space-7);
  }

  .cable-signs__grid {
    list-style: none;
    padding: 0;
    margin: var(--space-5) 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: var(--space-3);
    font-weight: 500;
  }

  .cable-signs__grid li {
    display: flex;
    align-items: center;
    background: var(--ez-concrete);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
  }

  .cable-signs__safety {
    margin-top: var(--space-5);
    padding: var(--space-4) var(--space-5);
    background: var(--ez-orange-tint);
    border-left: 4px solid var(--ez-orange);
    border-radius: var(--radius-sm);
    max-width: 44rem;
  }

  .cable-quote {
    background: var(--ez-concrete);
    padding-block: var(--space-7);
  }

  .cable-quote p {
    margin-top: var(--space-4);
    font-size: var(--text-lg);
  }

  .cable-final {
    background: var(--ez-charcoal);
    color: #c3ccd6;
    padding-block: var(--space-7);
    text-align: center;
  }

  .cable-final h2 {
    color: #fff;
  }

  .cable-final p {
    margin-block: var(--space-3) var(--space-5);
  }
</style>
