---
/**
 * Cable / roller / track repair — expanded phone-first urgency page:
 * full-bleed hero, proof bar, signs, causes, written-quote, gallery, FAQ.
 */
import LandingLayout from "../layouts/LandingLayout.astro";
import ServiceHero from "../components/ServiceHero.astro";
import ProofColumns from "../components/home/ProofColumns.astro";
import WorkGallery from "../components/WorkGallery.astro";
import FaqList from "../components/FaqList.astro";
import CallButton from "../components/CallButton.astro";
import SectionHeading from "../components/SectionHeading.astro";

const signs = [
  "Cable hanging loose or coiled on the floor",
  "Door lifts crooked or shudders on the way up",
  "One side higher than the other",
  "Grinding or scraping from the tracks",
  "Rollers popping or binding mid-travel",
  "Frayed cable strands near the bottom bracket",
];

const service = {
  name: "Garage Door Cable, Roller & Track Repair",
  description: "Snapped cables, worn rollers, and bent tracks repaired — door realigned and balanced with a written quote before work.",
  url: "/garage-door-cable-repair/",
};

const faqs = [
  { question: "The cable came off but the door still moves — is that OK?", answer: "No. A slipped cable puts the door's full weight on one side; every cycle bends tracks and wears the good cable. Stop running the opener and call." },
  { question: "Why did the cable snap?", answer: "Cables fray where they meet the bottom bracket — moisture, age, and an out-of-balance door speed it up. We check the spring balance behind it, because a cable that 'just slipped' usually slipped for a reason." },
  { question: "Do you replace both cables?", answer: "Usually yes — both cables have the same age and wear. Replacing the pair keeps the door lifting evenly and saves a second visit." },
  { question: "Can bent track be repaired, or does it need replacing?", answer: "Minor bends can often be trued; kinked or crushed sections get replaced. You'll see which one your door needs — with the price — in the written quote before any work." },
];
---

<LandingLayout
  title="Garage Door Cable Repair in Connecticut | EZ Garage Doors"
  description="Cable came off, rollers worn, or tracks bent? EZ Garage Doors repairs cables, rollers, and tracks across Connecticut — written quote before work begins."
  callLabel="Call for Cable Repair"
  service={service}
>
  <ServiceHero
    imageId="stuck-repair"
    eyebrow="Cable · Roller · Track"
    heading="Garage Door Cable & Track Repair"
    sub="Cable came off the drum, rollers worn out, or the door pulling crooked? Stop running the opener — a loose cable gets worse with every cycle."
    callLabel="Call for Cable Repair"
    callTrack="cable_call_click"
    secondaryLabel="Text a Photo of the Cable"
  />

  <ProofColumns />

  <section class="section">
    <div class="wrap">
      <SectionHeading eyebrow="Diagnosis" title="What a failing cable or track looks like" />
      <ul class="cable-signs">
        {
          signs.map((sign) => (
            <li>
              <span class="speed-tick" aria-hidden="true" />
              {sign}
            </li>
          ))
        }
      </ul>
      <p class="cable-safety">
        <strong>Careful:</strong> cables are under the same tension as the springs. Don't pull,
        rewind, or unbolt anything — keep the door still until it's serviced.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="wrap wrap--narrow">
      <SectionHeading eyebrow="Why written matters" title="Written quote before the repair" />
      <p>
        We check the cables, drums, rollers, tracks, and the spring balance behind them. You get
        what failed, why, and the price <strong>in writing before work begins</strong>.
      </p>
    </div>
  </section>

  <WorkGallery
    heading="Track and hardware work"
    imageIds={["walkthrough", "new-springs", "broken-spring"]}
  />

  <FaqList faqs={faqs} heading="Cable & track questions" />

  <section class="cable-final">
    <div class="wrap cable-final__inner">
      <h2>Door pulling crooked right now?</h2>
      <p>Call EZ Garage Doors — fast local cable, roller, and track repair.</p>
      <CallButton label="Call for Cable Repair" size="lg" track="cable_call_click" />
    </div>
  </section>
</LandingLayout>

<style>
  .cable-signs {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: var(--space-3);
    font-weight: 500;
  }

  .cable-signs li {
    display: flex;
    align-items: center;
    background: var(--ez-concrete);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
  }

  .cable-safety {
    margin-top: var(--space-5);
    padding: var(--space-4) var(--space-5);
    background: var(--ez-orange-tint);
    border-left: 4px solid var(--ez-orange);
    border-radius: var(--radius-sm);
    max-width: 44rem;
  }

  .cable-final {
    background: var(--ez-charcoal);
    color: #c3ccd6;
    padding-block: var(--space-7);
    text-align: center;
  }

  .cable-final h2 {
    color: #fff;
  }

  .cable-final p {
    margin-block: var(--space-3) var(--space-5);
  }
</style>
