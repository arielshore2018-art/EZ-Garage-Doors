---
/**
 * Service-area hub. Towns render as a grid; only cities with
 * published: true (real local proof) get dedicated pages —
 * no token-swap doorway pages.
 */
import SiteLayout from "../../layouts/SiteLayout.astro";
import ServiceHero from "../../components/ServiceHero.astro";
import ProofColumns from "../../components/home/ProofColumns.astro";
import CityGrid from "../../components/CityGrid.astro";
import CTASection from "../../components/CTASection.astro";
import { BUSINESS } from "../../config/business";
---

<SiteLayout
  title="Service Areas | EZ Garage Doors — Central Connecticut"
  description="EZ Garage Doors serves central Connecticut towns including Middletown, Cromwell, Glastonbury, West Hartford, Southington, and surrounding communities."
>
  <ServiceHero
    imageId="tech-arrival"
    eyebrow="Service Area"
    heading={`Garage Door Service Across Central ${BUSINESS.state}`}
    sub="One local team covering the towns below for repair, springs, openers, and new door installations. If your town borders this area, call — we can usually help."
    callLabel="Call EZ Garage Doors"
    callTrack="areas_call_click"
    secondaryLabel="Get a Written Estimate"
    secondaryHref="/contact/#request"
  />

  <ProofColumns />

  <CityGrid heading="Towns we serve" compact />

  <CTASection
    heading="In our area and need a hand?"
    sub="Call EZ Garage Doors or request a written estimate — we'll confirm coverage on the spot."
  />
</SiteLayout>

