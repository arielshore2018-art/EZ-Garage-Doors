---
/**
 * Off-track repair — expanded urgency page: full-bleed hero with
 * safety alert, proof bar, causes, quote promise, gallery, FAQ.
 */
import LandingLayout from "../layouts/LandingLayout.astro";
import ServiceHero from "../components/ServiceHero.astro";
import ProofColumns from "../components/home/ProofColumns.astro";
import WorkGallery from "../components/WorkGallery.astro";
import FaqList from "../components/FaqList.astro";
import CallButton from "../components/CallButton.astro";
import SectionHeading from "../components/SectionHeading.astro";

const causes = [
  "A snapped or slipped lift cable on one side",
  "Worn rollers popping out of the track",
  "A bent track from a bump or impact",
  "Running the opener against a jammed door",
  "Broken hinge letting a panel fold",
];

const service = {
  name: "Off-Track Garage Door Repair",
  description: "Garage door off its track secured, realigned, and rolling straight — with a written quote before work begins.",
  url: "/garage-door-off-track-repair/",
};

const faqs = [
  { question: "The door is hanging crooked — will it fall?", answer: "It can. An off-track door is held by whatever hardware hasn't failed yet. Keep people, pets, and cars away and don't run the opener again." },
  { question: "Can I push the rollers back into the track myself?", answer: "Please don't — the door's weight and spring tension make that dangerous, and forcing rollers back without fixing the cause puts it right back off track." },
  { question: "What does the repair involve?", answer: "We secure the door, find what pulled it off (cable, roller, or track), correct that, realign the door, and test full travel. The price is in writing before any of it starts." },
  { question: "My car is stuck behind the crooked door — what now?", answer: "Don't force the door. Call with your town — trapped-car calls are exactly what fast local dispatch is for." },
];
---

<LandingLayout
  title="Garage Door Off Track? Repair in Connecticut | EZ Garage Doors"
  description="Garage door came off its track or hangs crooked? Stop the opener and call EZ Garage Doors — fast local off-track repair with a written quote first."
  callLabel="Call Now"
  service={service}
>
  <ServiceHero
    imageId="before-old-wood"
    eyebrow="Off-Track Door Service"
    heading="Garage Door Off Its Track?"
    sub="Stop using the opener right now — every cycle bends the tracks further and can drop the door. We secure it, realign it, and get it rolling straight."
    callLabel="Call Now"
    callTrack="offtrack_call_click"
    secondaryLabel="Text a Photo of the Door"
    alert="Keep people, pets, and cars away from an off-track door. It can shift or fall without warning."
  />

  <ProofColumns />

  <section class="section">
    <div class="wrap">
      <SectionHeading eyebrow="Root cause" title="Why doors come off the track" />
      <ul class="ot-causes">
        {
          causes.map((cause) => (
            <li>
              <span class="speed-tick" aria-hidden="true" />
              {cause}
            </li>
          ))
        }
      </ul>
      <p class="ot-note">
        The fix is rarely just "push it back in" — whatever pulled it off has to be corrected
        too, or it happens again next week. That's what we inspect for.
      </p>
    </div>
  </section>

  <section class="section section--alt">
    <div class="wrap wrap--narrow">
      <SectionHeading eyebrow="The process" title="Secured, diagnosed, quoted in writing" />
      <p>
        We secure the door so it can't fall, find what pulled it off the track, and hand you the
        repair price <strong>in writing before work begins</strong>. You approve it — then we fix
        it and test the full travel.
      </p>
    </div>
  </section>

  <WorkGallery
    heading="Track realignment work"
    imageIds={["stuck-repair", "walkthrough", "new-springs"]}
  />

  <FaqList faqs={faqs} heading="Off-track door questions" />

  <section class="ot-final">
    <div class="wrap ot-final__inner">
      <h2>Door hanging crooked right now?</h2>
      <p>Don't force it. Call EZ Garage Doors for fast local off-track repair.</p>
      <CallButton label="Call Now" size="lg" track="offtrack_call_click" />
    </div>
  </section>
</LandingLayout>

<style>
  .ot-causes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: var(--space-3);
    font-weight: 500;
  }

  .ot-causes li {
    display: flex;
    align-items: center;
    background: var(--ez-concrete);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
  }

  .ot-note {
    margin-top: var(--space-5);
    max-width: 44rem;
  }

  .ot-final {
    background: var(--ez-charcoal);
    color: #c3ccd6;
    padding-block: var(--space-7);
    text-align: center;
  }

  .ot-final h2 {
    color: #fff;
  }

  .ot-final p {
    margin-block: var(--space-3) var(--space-5);
  }
</style>
