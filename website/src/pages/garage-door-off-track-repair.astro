---
/**
 * Off-track door repair — phone-first urgency landing page.
 * Security/safety framing, stripped layout, short.
 */
import LandingLayout from "../layouts/LandingLayout.astro";
import CallButton from "../components/CallButton.astro";
import MicroTrustBar from "../components/MicroTrustBar.astro";
import { APPROVED_CLAIMS } from "../config/business";

const causes = [
  "A snapped or slipped lift cable on one side",
  "Worn rollers popping out of the track",
  "A bent track from a bump or impact",
  "Running the opener against a jammed door",
  "Broken hinge letting a panel fold",
];

const service = {
  name: "Off-Track Garage Door Repair",
  description: "Garage door off its track secured, realigned, and rolling straight — with a written quote before work begins.",
  url: "/garage-door-off-track-repair/",
};
---

<LandingLayout
  title="Garage Door Off Track? Repair in Connecticut | EZ Garage Doors"
  description="Garage door came off its track or hangs crooked? Stop the opener and call EZ Garage Doors — fast local off-track repair with a written quote first."
  callLabel="Call Now"
  service={service}
>
  <section class="ot-hero">
    <div class="wrap ot-hero__inner">
      <h1>Garage Door Off Its Track?</h1>
      <p class="ot-hero__sub">
        Stop using the opener right now — every cycle bends the tracks further and can drop the
        door. Call EZ Garage Doors to secure it, realign it, and get it rolling straight.
      </p>
      <div class="ot-hero__safety" role="alert">
        <strong>Safety first:</strong> keep people, pets, and cars away from an off-track door.
        It can shift or fall without warning.
      </div>
      <div class="ot-hero__actions">
        <CallButton label="Call Now" size="lg" track="offtrack_call_click" />
        <a href="/contact/#request" class="btn btn--inverse-outline btn--lg" data-track="photo_cta_click">
          Text a Photo of the Door
        </a>
      </div>
      <div class="ot-hero__trust">
        <MicroTrustBar
          tone="dark"
          items={[APPROVED_CLAIMS.years, APPROVED_CLAIMS.local, APPROVED_CLAIMS.writtenQuote]}
        />
      </div>
    </div>
  </section>

  <section class="ot-causes">
    <div class="wrap">
      <h2>Why doors come off the track</h2>
      <span class="speed-rail" aria-hidden="true"></span>
      <ul class="ot-causes__grid">
        {
          causes.map((cause) => (
            <li>
              <span class="speed-tick" aria-hidden="true" />
              {cause}
            </li>
          ))
        }
      </ul>
      <p class="ot-causes__note">
        The fix is rarely just "push it back in" — whatever pulled it off (cable, roller, track)
        has to be corrected too, or it happens again next week. That's what we inspect for.
      </p>
    </div>
  </section>

  <section class="ot-quote">
    <div class="wrap wrap--narrow">
      <h2>Secured, diagnosed, quoted in writing</h2>
      <span class="speed-rail" aria-hidden="true"></span>
      <p>
        We secure the door so it can't fall, find what pulled it off the track, and hand you the
        repair price <strong>in writing before work begins</strong>. You approve it — then we fix
        it and test the full travel.
      </p>
    </div>
  </section>

  <section class="ot-final">
    <div class="wrap ot-final__inner">
      <h2>Door hanging crooked right now?</h2>
      <p>Don't force it. Call EZ Garage Doors for fast local off-track repair.</p>
      <CallButton label="Call Now" size="lg" track="offtrack_call_click" />
    </div>
  </section>
</LandingLayout>

<style>
  .ot-hero {
    background: var(--ez-charcoal);
    color: #c3ccd6;
    padding-block: var(--space-7);
    border-bottom: 4px solid var(--ez-orange);
  }

  .ot-hero h1 {
    color: #fff;
    max-width: 40rem;
  }

  .ot-hero__sub {
    font-size: var(--text-lg);
    margin-top: var(--space-4);
    max-width: 38rem;
    color: #b8c1cc;
  }

  .ot-hero__safety {
    margin-top: var(--space-4);
    padding: var(--space-4) var(--space-5);
    background: rgb(242 106 27 / 0.14);
    border-left: 4px solid var(--ez-orange);
    border-radius: var(--radius-sm);
    max-width: 38rem;
    color: #e6eaef;
  }

  .ot-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  .ot-hero__trust {
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid rgb(255 255 255 / 0.15);
  }

  .ot-causes {
    padding-block: var(--space-7);
  }

  .ot-causes__grid {
    list-style: none;
    padding: 0;
    margin: var(--space-5) 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(17rem, 1fr));
    gap: var(--space-3);
    font-weight: 500;
  }

  .ot-causes__grid li {
    display: flex;
    align-items: center;
    background: var(--ez-concrete);
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
  }

  .ot-causes__note {
    margin-top: var(--space-5);
    max-width: 44rem;
  }

  .ot-quote {
    background: var(--ez-concrete);
    padding-block: var(--space-7);
  }

  .ot-quote p {
    margin-top: var(--space-4);
    font-size: var(--text-lg);
  }

  .ot-final {
    background: var(--ez-charcoal);
    color: #c3ccd6;
    padding-block: var(--space-7);
    text-align: center;
  }

  .ot-final h2 {
    color: #fff;
  }

  .ot-final p {
    margin-block: var(--space-3) var(--space-5);
  }
</style>
