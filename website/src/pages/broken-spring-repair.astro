---
/**
 * Broken spring repair — expanded: full-bleed torsion-work hero with
 * safety alert, proof bar, spring imagery, torsion vs extension,
 * process, gallery, reviews, FAQ.
 */
import { Image } from "astro:assets";
import SiteLayout from "../layouts/SiteLayout.astro";
import ServiceHero from "../components/ServiceHero.astro";
import ProofColumns from "../components/home/ProofColumns.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import WorkGallery from "../components/WorkGallery.astro";
import ProofBand from "../components/ProofBand.astro";
import FaqList from "../components/FaqList.astro";
import CTASection from "../components/CTASection.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { img } from "../config/site-images";

const signs = [
  "A loud bang from the garage — like something snapped",
  "The door suddenly feels far too heavy to lift",
  "A visible gap in the spring coil above the door",
  "The door opens a few inches, then stops",
  "Cables hanging loose or off their drums",
  "The door slams shut faster than normal",
];

const brokenSpringImg = img("broken-spring");

const service = {
  name: "Broken Garage Door Spring Repair",
  description: "Torsion and extension spring replacement for residential garage doors, with a written quote before work begins.",
  url: "/broken-spring-repair/",
};

const faqs = [
  { question: "Can I open the door with a broken spring?", answer: "Don't. The spring carries the door's weight — without it the opener strains and the door can drop. Leave it down, keep people and cars clear, and call." },
  { question: "My car is trapped inside — can you help today?", answer: "That's one of the most common calls we get. Call with your town and we'll tell you honestly what today's availability looks like." },
  { question: "Why replace both springs on a two-spring door?", answer: "Both springs have the same cycle life. When one snaps, the other is at the end of its life too — replacing both keeps the door balanced and saves you a second visit." },
  { question: "How long does a spring replacement take?", answer: "Most residential spring replacements are done in a single visit — vans are stocked with common spring sizes. We confirm on the phone after you describe the door." },
  { question: "Will the new springs last longer?", answer: "Springs are rated in cycles, not years. We match the spring to your door's weight and can quote higher-cycle springs if you use the door heavily." },
];
---

<SiteLayout
  title="Broken Garage Door Spring Repair in Connecticut | EZ Garage Doors"
  description="Heard a loud bang? Door too heavy to lift? Broken garage door spring repair in Connecticut — torsion and extension springs replaced with a written quote first."
  service={service}
  faqs={faqs}
>
  <ServiceHero
    imageId="spring-winding"
    eyebrow="Spring Service"
    heading="Broken Garage Door Spring Repair"
    sub="If you heard a loud bang or your door suddenly feels too heavy, stop using it and call EZ Garage Doors for spring service."
    callLabel="Call for Spring Repair"
    callTrack="spring_call_click"
    alert="Do not try to lift or force the door. Garage door springs are under high tension and can be dangerous."
  />

  <ProofColumns />

  <section class="section section--alt">
    <div class="wrap signs">
      <div>
        <SectionHeading eyebrow="Diagnosis" title="Signs your spring is broken" />
        <ul class="signs__list">
          {
            signs.map((sign) => (
              <li>
                <span class="speed-tick" aria-hidden="true" />
                {sign}
              </li>
            ))
          }
        </ul>
      </div>
      <figure class="signs__media track-frame track-frame--br">
        <Image
          src={brokenSpringImg.src}
          alt={brokenSpringImg.alt}
          width={720}
          widths={[480, 720]}
          sizes="(max-width: 62rem) 92vw, 440px"
          loading="lazy"
        />
        <figcaption>
          <span class="speed-tick" aria-hidden="true"></span>
          The tell: a visible gap in the coil above the door.
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="section">
    <div class="wrap wrap--narrow">
      <SectionHeading eyebrow="Two spring systems" title="Torsion vs. extension springs" />
      <p>
        <strong>Torsion springs</strong> sit on a shaft above the door and fail with a loud bang —
        most modern doors use one or two, replaced in pairs to keep the door balanced.
        <strong> Extension springs</strong> stretch along the side tracks and should always have
        safety cables through them; if yours don't, we fix that in the same visit.
      </p>
      <p class="muted">
        Spring jobs are the classic bait-and-switch trap in this industry — a cheap teaser price
        by phone, then "surprises" at the door. We quote the spring system your door actually
        has, in writing, before work begins.
      </p>
    </div>
  </section>

  <ProcessSteps
    heading="How a spring repair visit works"
    steps={[
      { title: "Stop using the door", detail: "A broken spring means the opener is lifting weight it was never built for." },
      { title: "Call and describe it", detail: "Door size and what happened — a photo of the spring helps." },
      { title: "Written quote on site", detail: "We confirm the spring system and hand you the price in writing first." },
      { title: "Replaced, balanced, tested", detail: "New springs installed, door balanced, opener travel checked before we leave." },
    ]}
  />

  <WorkGallery
    heading="Spring work, up close"
    imageIds={["spring-safety", "new-springs", "walkthrough"]}
  />

  <ProofBand heading="The spring calls we get rated on" />

  <FaqList faqs={faqs} heading="Broken spring questions" />

  <CTASection
    heading="Broken spring? Don't force the door."
    sub="Call EZ Garage Doors for spring service with a written quote before work begins."
    callLabel="Call for Spring Repair"
  />
</SiteLayout>

<style>
  .signs {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: var(--space-7);
    align-items: center;
  }

  .signs__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-3);
    font-weight: 500;
  }

  .signs__list li {
    display: flex;
    align-items: center;
    background: var(--ez-white);
    border: 1px solid var(--ez-line);
    padding: var(--space-3) var(--space-4);
  }

  .signs__media {
    margin: 0;
    position: relative;
  }

  .signs__media img {
    width: 100%;
    height: auto;
  }

  .signs__media figcaption {
    display: flex;
    align-items: center;
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  @media (max-width: 62rem) {
    .signs {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>
