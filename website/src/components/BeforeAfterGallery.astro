---
/**
 * Before/after pairs. Captions describe the door style only — never
 * attributed to a named town or customer unless the owner confirms
 * a specific real job.
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import SectionHeading from "./SectionHeading.astro";

interface Pair {
  before: ImageMetadata;
  after: ImageMetadata;
  caption: string;
}

interface Props {
  pairs: Pair[];
  heading?: string;
}

const { pairs, heading = "Before and after" } = Astro.props;
---

<section class="section section--alt" aria-labelledby="before-after-heading">
  <div class="wrap">
    <SectionHeading eyebrow="The difference a door makes" title={heading} />
    <div class="ba-grid">
      {
        pairs.map((pair) => (
          <figure class="ba-pair">
            <div class="ba-pair__images">
              <div class="ba-pair__frame">
                <span class="ba-pair__tag">Before</span>
                <Image
                  src={pair.before}
                  alt={`Before: ${pair.caption}`}
                  width={640}
                  widths={[420, 640]}
                  sizes="(max-width: 48rem) 46vw, 320px"
                  loading="lazy"
                />
              </div>
              <div class="ba-pair__frame">
                <span class="ba-pair__tag ba-pair__tag--after">After</span>
                <Image
                  src={pair.after}
                  alt={`After: ${pair.caption}`}
                  width={640}
                  widths={[420, 640]}
                  sizes="(max-width: 48rem) 46vw, 320px"
                  loading="lazy"
                />
              </div>
            </div>
            <figcaption>{pair.caption}</figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .ba-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 20rem), 1fr));
    gap: var(--space-6);
  }

  .ba-pair__images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2);
  }

  .ba-pair__frame {
    position: relative;
    overflow: hidden;
  }

  .ba-pair__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 3;
  }

  .ba-pair__tag {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 1;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--ez-charcoal);
    color: #fff;
    padding: 0.2rem 0.55rem;
    border-radius: var(--radius-sm);
  }

  .ba-pair__tag--after {
    background: var(--ez-orange);
  }

  figcaption {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
