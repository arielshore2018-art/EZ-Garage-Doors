---
/**
 * Photographic repair-category strip: three tiles understood before
 * they are read. Image fills the tile; text is a compact overlay.
 * Desktop: one large + two stacked (asymmetric). Mobile: full-width tiles.
 */
import { Image } from "astro:assets";

import imgSpring from "../../assets/photos/ez-garage-door-broken-torsion-spring.png";
import imgOpener from "../../assets/photos/opener-rail-detail.jpg";
import imgOffTrack from "../../assets/photos/ez-garage-door-stuck-door-repair.jpg";

const tiles = [
  {
    title: "Broken Spring",
    symptom: "Heard a loud bang? Door suddenly feels too heavy?",
    img: imgSpring,
    alt: "Snapped garage door torsion spring with a visible gap in the coil",
    href: "/broken-spring-repair/",
    track: "visual_spring",
    large: true,
  },
  {
    title: "Opener Problem",
    symptom: "Motor runs, but the door won't move?",
    img: imgOpener,
    alt: "Garage door opener rail, trolley, and red emergency release cord",
    href: "/garage-door-opener-repair/",
    track: "visual_opener",
    large: false,
  },
  {
    title: "Door Off Track",
    symptom: "Door crooked, cable loose, or rollers outside the track?",
    img: imgOffTrack,
    alt: "Technician servicing a garage door roller and track",
    href: "/garage-door-off-track-repair/",
    track: "visual_offtrack",
    large: false,
  },
];
---

<section class="rvg section" aria-label="Common garage door repairs">
  <div class="wrap rvg__grid">
    {
      tiles.map((tile) => (
        <a
          href={tile.href}
          class:list={["rvg__tile", { "rvg__tile--large": tile.large }]}
          data-track={tile.track}
        >
          <Image
            src={tile.img}
            alt={tile.alt}
            width={tile.large ? 980 : 640}
            widths={tile.large ? [520, 760, 980] : [420, 640]}
            sizes={
              tile.large
                ? "(max-width: 62rem) 92vw, 640px"
                : "(max-width: 62rem) 92vw, 420px"
            }
            loading="lazy"
          />
          <span class="rvg__caption">
            <strong>{tile.title}</strong>
            <span>{tile.symptom}</span>
          </span>
        </a>
      ))
    }
  </div>
</section>

<style>
  .rvg {
    padding-block: var(--space-6);
  }

  .rvg__grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
    grid-template-rows: repeat(2, minmax(0, 1fr));
  }

  .rvg__tile {
    position: relative;
    display: block;
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
  }

  .rvg__tile--large {
    grid-row: 1 / 3;
  }

  .rvg__tile :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .rvg__tile--large :global(img) {
    min-height: 100%;
  }

  .rvg__caption {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: var(--space-6) var(--space-4) var(--space-3);
    background: linear-gradient(180deg, transparent 0%, rgb(20 28 38 / 0.82) 78%);
    color: #fff;
  }

  .rvg__caption strong {
    display: flex;
    align-items: center;
    font-family: var(--font-display);
    font-weight: 750;
    font-size: var(--text-lg);
  }

  .rvg__caption strong::before {
    content: "";
    width: 1rem;
    height: 3px;
    border-radius: 2px;
    background: var(--ez-orange);
    margin-right: var(--space-2);
  }

  .rvg__caption span {
    display: block;
    font-size: var(--text-sm);
    color: #d6dce3;
    margin-top: 0.15rem;
  }

  @media (max-width: 62rem) {
    .rvg__grid {
      grid-template-columns: 1fr;
      grid-template-rows: none;
    }

    .rvg__tile--large {
      grid-row: auto;
    }

    .rvg__tile :global(img) {
      aspect-ratio: 16 / 9;
    }
  }
</style>
