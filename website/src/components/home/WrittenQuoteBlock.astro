---
/**
 * Written-quote promise — exactly 3 steps, thin orange accent,
 * deliberately light and calm (not a heavy "how it works" block).
 */
const steps = [
  { title: "Tell us what happened", detail: "Stuck, bang, humming opener — a photo helps." },
  { title: "We inspect the door", detail: "We find what failed and explain it plainly." },
  { title: "You approve the written quote", detail: "The price, in writing, before any work." },
];

import { Image } from "astro:assets";
import quoteTablet from "../../assets/photos/ez-garage-door-written-quote-tablet.jpg";
---

<section class="quote-block">
  <div class="wrap quote-block__inner">
    <div class="quote-block__head">
      <h2>You'll Know the Price Before Work Begins</h2>
      <span class="speed-rail" aria-hidden="true"></span>
      <p>
        We inspect the problem, explain what failed, and give you a written quote before repair
        work starts.
      </p>
    </div>
    <div class="quote-block__media">
      <Image
        src={quoteTablet}
        alt="Technician showing a written garage door repair quote on a tablet to a customer"
        width={760}
        widths={[480, 760]}
        sizes="(max-width: 62rem) 92vw, 460px"
        loading="lazy"
      />
    </div>
    <ol class="quote-block__steps">
      {
        steps.map((step, i) => (
          <li>
            <span class="quote-block__num" aria-hidden="true">
              {i + 1}
            </span>
            <div>
              <h3>{step.title}</h3>
              <p>{step.detail}</p>
            </div>
          </li>
        ))
      }
    </ol>
    <p class="quote-block__support">
      No surprise work. No pressure. No repair starts until you understand the quote.
    </p>
  </div>
</section>

<style>
  .quote-block {
    padding-block: var(--space-section);
    border-top: 4px solid var(--ez-orange);
    background: #fff;
  }

  .quote-block__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 0.8fr);
    gap: clamp(var(--space-6), 4vw, var(--space-8));
    align-items: center;
  }

  .quote-block__head {
    max-width: 40rem;
  }

  .quote-block__media {
    grid-column: 2;
    grid-row: 1 / 4;
  }

  .quote-block__media img {
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    width: 100%;
    height: auto;
  }

  @media (max-width: 62rem) {
    .quote-block__inner {
      grid-template-columns: 1fr;
    }

    .quote-block__media {
      grid-column: 1;
      grid-row: auto;
      order: 4;
    }
  }

  .quote-block__head p {
    margin-top: var(--space-4);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
  }

  .quote-block__steps {
    list-style: none;
    padding: 0;
    margin: var(--space-6) 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: var(--space-5);
  }

  .quote-block__steps li {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .quote-block__num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-2xl);
    line-height: 1;
    color: var(--ez-orange);
  }

  .quote-block__steps h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
  }

  .quote-block__steps p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .quote-block__support {
    margin-top: var(--space-6);
    padding-top: var(--space-4);
    border-top: 1px dashed var(--ez-border);
    font-family: var(--font-display);
    font-weight: 650;
    color: var(--ez-charcoal);
    max-width: 40rem;
  }
</style>
