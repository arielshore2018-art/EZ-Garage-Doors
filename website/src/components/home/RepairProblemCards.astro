---
/**
 * Repair problems — exactly 4 cards, no icon clutter, no feature-grid
 * feel. Each card is a symptom cluster linking to its repair page.
 */
import CallButton from "../CallButton.astro";
import SectionHeading from "../SectionHeading.astro";

const problems = [
  {
    title: "Door Won't Close",
    detail: "Security issue, sensor problem, track issue, opener failure, or stuck door.",
    href: "/garage-door-repair/",
    track: "problems_wont-close",
  },
  {
    title: "Broken Spring",
    detail: "Loud bang, heavy door, door won't lift, car trapped inside.",
    href: "/broken-spring-repair/",
    track: "problems_spring",
  },
  {
    title: "Opener Problems",
    detail: "Motor hums, remote fails, sensors blink, door reverses.",
    href: "/garage-door-opener-repair/",
    track: "problems_opener",
  },
  {
    title: "Cable / Track / Roller Issues",
    detail: "Crooked movement, loose cable, worn rollers, off-track door.",
    href: "/garage-door-cable-repair/",
    track: "problems_cable",
  },
];
---

<section class="problems section section--alt">
  <div class="wrap">
    <SectionHeading
      eyebrow="Repair first"
      title="We Fix the Problems That Stop Your Day"
    />
    <p class="problems__intro">
      Most repair calls start with the same few symptoms. If the door is stuck, heavy, crooked,
      noisy, or won't close, start here.
    </p>
    <ul class="problems__grid">
      {
        problems.map((p) => (
          <li>
            <a href={p.href} class="problems__card" data-track={p.track}>
              <h3>{p.title}</h3>
              <p>{p.detail}</p>
              <span class="problems__go" aria-hidden="true">→</span>
            </a>
          </li>
        ))
      }
    </ul>
    <div class="problems__cta">
      <CallButton label="Call for Repair Service" size="lg" track="problems_call_click" />
    </div>
  </div>
</section>

<style>
  .problems__intro {
    max-width: 40rem;
    margin-top: calc(-1 * var(--space-4));
    margin-bottom: var(--space-6);
    color: var(--color-text-muted);
  }

  .problems__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: var(--space-4);
  }

  .problems__card {
    position: relative;
    display: block;
    height: 100%;
    background: #fff;
    border: 1px solid var(--ez-border);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-5) var(--space-6);
    text-decoration: none;
    transition: border-color 120ms ease;
  }

  .problems__card::before {
    content: "";
    position: absolute;
    left: var(--space-5);
    top: 0;
    width: 2.6rem;
    height: 4px;
    border-radius: 0 0 2px 2px;
    background: var(--speed-line-gradient);
  }

  .problems__card:hover {
    border-color: var(--ez-orange);
  }

  .problems__card h3 {
    font-size: var(--text-lg);
    margin: var(--space-2) 0;
  }

  .problems__card p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .problems__go {
    position: absolute;
    right: var(--space-4);
    bottom: var(--space-3);
    color: var(--ez-orange);
    font-family: var(--font-display);
    font-weight: 700;
  }

  .problems__cta {
    margin-top: var(--space-6);
  }
</style>
