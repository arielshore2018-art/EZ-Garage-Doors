---
/**
 * Clean three-column proof section (replaces the old horizontal
 * stats banner): value over label, generous whitespace, no band.
 */
import { BUSINESS, STATS } from "../../config/business";

const stats = [
  { value: `${BUSINESS.yearsInBusiness} Years`, label: "In Business" },
  { value: STATS.fiveStarReviews, label: "Five-Star Reviews" },
  { value: STATS.repairs, label: "Repairs Completed" },
];
---

<section class="proof-cols">
  <ul class="wrap proof-cols__list" aria-label="EZ Garage Doors track record">
    {
      stats.map((s) => (
        <li>
          <span class="proof-cols__value">{s.value}</span>
          <span class="proof-cols__label">{s.label}</span>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .proof-cols {
    padding-block: clamp(var(--space-6), 5vw, var(--space-7));
  }

  .proof-cols__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
    list-style: none;
    margin: 0;
    text-align: center;
  }

  .proof-cols__list li {
    display: grid;
    gap: var(--space-1);
    justify-items: center;
  }

  .proof-cols__value {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.6rem, 1.2rem + 2vw, 2.4rem);
    color: var(--ez-charcoal);
    line-height: 1.05;
    padding-bottom: var(--space-2);
    position: relative;
  }

  .proof-cols__value::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 2.4rem;
    height: 3px;
    border-radius: 2px;
    background: var(--speed-line-gradient);
  }

  .proof-cols__label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  @media (max-width: 30rem) {
    .proof-cols__list {
      gap: var(--space-3);
    }

    .proof-cols__value {
      font-size: 1.35rem;
    }
  }
</style>
