---
/**
 * 2–3 short review cards from src/config/reviews.ts.
 * ⚠️ Current entries are owner-styled placeholders — REPLACE-BEFORE-LAUNCH
 * with verbatim real reviews + live links (see reviews.ts warning).
 */
import { featuredReviews } from "../../config/reviews";

interface Props {
  limit?: number;
}

const { limit = 3 } = Astro.props;
const items = featuredReviews.slice(0, limit);
---

<ul class="rc">
  {
    items.map((r) => (
      <li class="rc__card">
        <p class="rc__meta">
          <span class="rc__stars" aria-label="5 out of 5 stars">
            ★★★★★
          </span>
          <span class="rc__service">{r.service}</span>
        </p>
        <blockquote>
          <p>“{r.text}”</p>
          <footer>
            {r.name} · {r.town}, CT — <cite>{r.platform}</cite>
          </footer>
        </blockquote>
      </li>
    ))
  }
</ul>

<style>
  .rc {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-4);
  }

  .rc__card {
    background: #fff;
    border: 1px solid var(--ez-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .rc__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin: 0 0 var(--space-3);
  }

  .rc__stars {
    color: var(--ez-orange);
    letter-spacing: 0.1em;
    font-size: var(--text-sm);
  }

  .rc__service {
    font-family: var(--font-display);
    font-weight: 650;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ez-steel);
  }

  .rc__card blockquote {
    margin: 0;
  }

  .rc__card blockquote p {
    font-size: var(--text-sm);
    margin-bottom: var(--space-3);
  }

  .rc__card footer {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .rc__card cite {
    font-style: normal;
    font-weight: 650;
  }
</style>
