---
/**
 * Full-bleed overlay hero (v7). ONE integrated composition on every
 * breakpoint: the repair image fills the hero, copy/CTA/rating sit
 * directly on layered gradients — no detached panels, no seams.
 * Mobile: portrait crop, text near the bottom over a bottom gradient,
 * door visible in the upper/middle. Desktop: wide crop, text lower-left
 * over a left gradient.
 */
import { getImage, Image } from "astro:assets";
import CallButton from "../CallButton.astro";
import heroDesktopSrc from "../../assets/photos/hero-active-repair-desktop.jpg";
import heroMobileSrc from "../../assets/photos/hero-active-repair-mobile-portrait.jpg";
import googleWhite from "../../assets/trust-logos/review-platforms/google-logo-white.png";
import yelpWhite from "../../assets/trust-logos/review-platforms/yelp-logo-white.png";
import angiWhite from "../../assets/trust-logos/review-platforms/angi-logo-white.png";
import { STATS } from "../../config/business";

const desktop = await getImage({
  src: heroDesktopSrc,
  format: "webp",
  widths: [1000, 1440, 1920],
  sizes: "100vw",
});

const mobile = await getImage({
  src: heroMobileSrc,
  format: "webp",
  widths: [480, 690],
  sizes: "100vw",
});

const platformLogos = [
  { img: googleWhite, alt: "Google reviews platform logo", h: 20 },
  { img: yelpWhite, alt: "Yelp reviews platform logo", h: 22 },
  { img: angiWhite, alt: "Angi reviews platform logo", h: 22 },
];

const dims = (img: { width: number; height: number }, h: number) => ({
  height: h,
  width: Math.round(img.width * (h / img.height)),
});

const STAR_PATH = "M12 1.8l3.1 6.3 6.9 1-5 4.9 1.2 6.9L12 17.6 5.8 20.9 7 14 2 9.1l6.9-1z";
---

<section class="hero7">
  <picture class="hero7__bg" aria-hidden="true">
    <source media="(min-width: 62rem)" srcset={desktop.srcSet.attribute} sizes="100vw" />
    <img
      src={mobile.src}
      srcset={mobile.srcSet.attribute}
      sizes="100vw"
      alt=""
      width={heroMobileSrc.width}
      height={heroMobileSrc.height}
      loading="eager"
      fetchpriority="high"
      decoding="sync"
    />
  </picture>
  <span class="hero7__overlay" aria-hidden="true"></span>

  <div class="hero7__content">
    <p class="hero7__eyebrow">
      <span class="speed-tick" aria-hidden="true"></span>
      Connecticut Garage Door Repair
    </p>
    <h1>Door Stuck or Won't Close?</h1>
    <p class="hero7__sub">
      Fast local repair for broken springs, openers, cables, tracks, and doors that won't close.
    </p>
    <div class="hero7__actions">
      <CallButton label="Call for Repair" size="lg" track="hero_call_click" />
      <a href="/contact/#request" class="hero7__photo-link" data-track="photo_cta_click">
        <svg
          aria-hidden="true"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"></path>
          <circle cx="12" cy="13" r="3"></circle>
        </svg>
        Send a Photo
      </a>
    </div>
    <p class="hero7__micro">Written quote before work begins.</p>

    <div class="hero7__proof" role="img" aria-label="Rated 4.9 out of 5 based on more than 850 reviews">
      <p class="hero7__rating" aria-hidden="true">
        <span class="hero7__stars">
          {
            [0, 1, 2, 3, 4].map(() => (
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#f0a828">
                <path d={STAR_PATH} />
              </svg>
            ))
          }
        </span>
        <span class="hero7__score">4.9 · {STATS.fiveStarReviews} reviews</span>
      </p>
      <p class="hero7__platforms" aria-hidden="true">
        {
          platformLogos.map((p) => {
            const d = dims(p.img, p.h);
            return <Image src={p.img} alt="" width={d.width} height={d.height} loading="eager" />;
          })
        }
      </p>
    </div>
  </div>
</section>

<style>
  .hero7 {
    position: relative;
    display: flex;
    overflow: hidden;
    min-height: clamp(640px, 92vh, 720px);
    align-items: flex-end;
  }

  .hero7__bg {
    position: absolute;
    inset: 0;
  }

  .hero7__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 24% 20%;
    display: block;
  }

  /* Mobile: bottom gradient — door stays visible up top */
  .hero7__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgb(13 21 31 / 0.05) 0%,
      rgb(13 21 31 / 0.16) 26%,
      rgb(13 21 31 / 0.55) 44%,
      rgb(13 21 31 / 0.88) 62%,
      rgb(13 21 31 / 0.97) 100%
    );
  }

  .hero7__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--content-max);
    margin-inline: auto;
    padding: var(--space-6) clamp(1rem, 4vw, 2rem) var(--space-6);
    color: #c9d2dc;
  }

  .hero7__eyebrow {
    display: flex;
    align-items: center;
    font-family: var(--font-display);
    font-weight: 750;
    font-size: var(--text-xs);
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--ez-orange);
    margin-bottom: var(--space-2);
  }

  .hero7__content h1 {
    color: #fff;
    font-size: clamp(2.1rem, 1.5rem + 2.8vw, 3.3rem);
    max-width: 14ch;
  }

  .hero7__sub {
    margin-top: var(--space-3);
    font-size: var(--text-base);
    max-width: 32rem;
    color: #d6dce3;
  }

  .hero7__actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .hero7__actions :global(.btn) {
    white-space: nowrap;
    min-height: 56px;
  }

  .hero7__photo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
    color: #fff;
    text-decoration-color: var(--ez-orange);
    min-height: 44px;
    white-space: nowrap;
  }

  .hero7__photo-link:hover {
    color: var(--ez-orange);
  }

  .hero7__micro {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: #9aa5b1;
  }

  .hero7__proof {
    margin-top: var(--space-4);
  }

  .hero7__rating {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin: 0;
  }

  .hero7__stars {
    display: inline-flex;
    gap: 4px;
    line-height: 0;
  }

  .hero7__score {
    font-family: var(--font-display);
    font-weight: 750;
    font-size: var(--text-base);
    color: #fff;
  }

  .hero7__platforms {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin: var(--space-3) 0 0;
    opacity: 0.92;
  }

  .hero7__platforms :global(img) {
    width: auto;
    display: block;
  }

  /* ---- Desktop: text lower-left over layered left gradient ---- */
  @media (min-width: 62rem) {
    .hero7 {
      min-height: 660px;
      align-items: center;
    }

    .hero7__bg img {
      object-position: 72% 30%;
    }

    .hero7__overlay {
      background:
        linear-gradient(
          90deg,
          rgb(13 21 31 / 0.92) 0%,
          rgb(13 21 31 / 0.72) 36%,
          rgb(13 21 31 / 0.18) 68%,
          rgb(13 21 31 / 0) 100%
        ),
        linear-gradient(0deg, rgb(13 21 31 / 0.35) 0%, rgb(13 21 31 / 0) 30%);
    }

    .hero7__content {
      padding-block: var(--space-8);
    }

    .hero7__content > * {
      max-width: 560px;
    }

    .hero7__stars svg {
      width: 22px;
      height: 22px;
    }
  }
</style>
