---
/**
 * Integrated photographic hero (v6). One composition: a full-bleed
 * active-repair image with a charcoal gradient from the left and the
 * headline/CTA/rating rendered directly over the darker side.
 * No floating white card, no detached panels.
 * Mobile keeps the proven order: image → copy → rating, as one block.
 */
import { Image } from "astro:assets";
import CallButton from "../CallButton.astro";
import HeroRatingProof from "../HeroRatingProof.astro";
import heroDesktop from "../../assets/photos/hero-active-repair-desktop.jpg";
import heroMobile from "../../assets/photos/hero-repair-mobile.jpg";
---

<section class="hero6">
  <!-- Mobile image band (desktop uses the background composition below) -->
  <div class="hero6__mobile-media">
    <Image
      src={heroMobile}
      alt="EZ Garage Doors technician repairing the torsion system of a residential garage door"
      width={990}
      widths={[480, 780, 990]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <div class="hero6__stage">
    <div class="hero6__bg" aria-hidden="true">
      <Image
        src={heroDesktop}
        alt=""
        width={1440}
        widths={[1000, 1440, 1920]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>

    <div class="hero6__content">
      <p class="hero6__eyebrow">
        <span class="speed-tick" aria-hidden="true"></span>
        Connecticut Garage Door Repair
      </p>
      <h1>Door Stuck or Won't Close?</h1>
      <p class="hero6__sub">
        Fast local repair for broken springs, openers, cables, tracks, and doors that won't
        close.
      </p>
      <div class="hero6__actions">
        <CallButton label="Call for Repair" size="lg" track="hero_call_click" />
        <a href="/contact/#request" class="hero6__photo-link" data-track="photo_cta_click">
          <svg
            aria-hidden="true"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"></path>
            <circle cx="12" cy="13" r="3"></circle>
          </svg>
          Send a Photo
        </a>
      </div>
      <p class="hero6__micro">Written quote before work begins.</p>
      <div class="hero6__rating">
        <HeroRatingProof tone="dark" />
      </div>
    </div>
  </div>
</section>

<style>
  /* ---------- Mobile: image band → copy block (one flowing unit) ---------- */
  .hero6__mobile-media :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .hero6__bg {
    display: none;
  }

  .hero6__content {
    background: var(--ez-charcoal);
    color: #c3ccd6;
    padding: var(--space-5) clamp(1rem, 4vw, 2rem) var(--space-6);
  }

  .hero6__eyebrow {
    display: flex;
    align-items: center;
    font-family: var(--font-display);
    font-weight: 750;
    font-size: var(--text-xs);
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--ez-orange);
    margin-bottom: var(--space-2);
  }

  .hero6__content h1 {
    color: #fff;
    font-size: clamp(2rem, 1.4rem + 2.8vw, 3rem);
  }

  .hero6__sub {
    margin-top: var(--space-3);
    font-size: var(--text-base);
    color: #c3ccd6;
    max-width: 33rem;
  }

  .hero6__actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .hero6__actions :global(.btn) {
    white-space: nowrap;
  }

  .hero6__photo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
    color: #fff;
    text-decoration-color: var(--ez-orange);
    min-height: 44px;
    white-space: nowrap;
  }

  .hero6__photo-link:hover {
    color: var(--ez-orange);
  }

  .hero6__micro {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: #8d98a5;
  }

  .hero6__rating {
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid rgb(255 255 255 / 0.14);
  }

  /* ---------- Desktop: one integrated photographic composition ---------- */
  @media (min-width: 62rem) {
    .hero6__mobile-media {
      display: none;
    }

    .hero6__stage {
      position: relative;
      min-height: 600px;
      display: flex;
      align-items: center;
      overflow: hidden;
    }

    .hero6__bg {
      display: block;
      position: absolute;
      inset: 0;
    }

    .hero6__bg :global(img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: 72% 30%;
    }

    /* Controlled charcoal gradient over the left half for white type */
    .hero6__bg::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(
        90deg,
        rgb(20 28 38 / 0.94) 0%,
        rgb(20 28 38 / 0.86) 30%,
        rgb(20 28 38 / 0.55) 48%,
        rgb(20 28 38 / 0) 68%
      );
    }

    .hero6__content {
      position: relative;
      z-index: 1;
      background: none;
      max-width: var(--content-max);
      width: 100%;
      margin-inline: auto;
      padding: var(--space-7) clamp(1rem, 4vw, 2rem);
    }

    .hero6__content > * {
      max-width: 540px;
    }

    .hero6__content h1 {
      font-size: clamp(2.6rem, 2rem + 1.8vw, 3.4rem);
    }

    .hero6__sub {
      font-size: var(--text-lg);
      margin-top: var(--space-4);
    }

    .hero6__actions {
      margin-top: var(--space-5);
    }
  }
</style>
