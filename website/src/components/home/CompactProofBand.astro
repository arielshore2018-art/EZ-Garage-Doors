---
/**
 * Proof section: compact stats, platform ratings with logos,
 * 3 short review cards, 3 work images. Deliberately compact —
 * no review wall, no carousel, no counters overload.
 */
import { Image } from "astro:assets";
import SectionHeading from "../SectionHeading.astro";
import ReviewCards from "./ReviewCards.astro";
import { reviews, REVIEWS_TOTAL_LINE } from "../../config/reviews";

import googleLogo from "../../assets/trust-logos/review-platforms/google-logo.webp";
import yelpLogo from "../../assets/trust-logos/review-platforms/yelp-logo.webp";
import angiLogo from "../../assets/trust-logos/review-platforms/angi-logo.webp";

import imgWinding from "../../assets/photos/ez-garage-door-spring-winding-repair.jpg";
import imgNewSprings from "../../assets/photos/ez-garage-door-new-torsion-springs.png";
import imgDoor from "../../assets/photos/ez-garage-door-charcoal-recessed-panel.png";

const platforms = [
  { key: "google", img: googleLogo, alt: "Google reviews platform logo", h: 24 },
  { key: "yelp", img: yelpLogo, alt: "Yelp reviews platform logo", h: 26 },
  { key: "angi", img: angiLogo, alt: "Angi reviews platform logo", h: 26 },
] as const;

const workImages = [
  { img: imgWinding, alt: "Technician winding a garage door torsion spring with winding bars" },
  { img: imgNewSprings, alt: "New torsion springs installed above a garage door" },
  { img: imgDoor, alt: "Completed charcoal recessed-panel garage door installation" },
];

const dims = (img: { width: number; height: number }, h: number) => ({
  height: h,
  width: Math.round(img.width * (h / img.height)),
});
---

<section class="proof section section--alt">
  <div class="wrap">
    <SectionHeading
      eyebrow="The track record"
      title="Trusted for Thousands of Local Garage Door Repairs"
    />

    <div class="proof__platforms">
      {
        platforms.map((p) => {
          const d = dims(p.img, p.h);
          const data = reviews[p.key];
          return (
            <span class="proof__platform">
              <Image src={p.img} alt={p.alt} width={d.width} height={d.height} loading="lazy" />
              {data.rating && data.count && (
                <span class="proof__rating">
                  {data.rating} · {data.count} reviews
                </span>
              )}
            </span>
          );
        })
      }
      <p class="proof__platform-line">Reviewed across major platforms by Connecticut homeowners.</p>
    </div>

    <ReviewCards limit={3} />
    <p class="proof__total">{REVIEWS_TOTAL_LINE}</p>

    <ul class="proof__work">
      {
        workImages.map((w) => (
          <li>
            <Image
              src={w.img}
              alt={w.alt}
              width={640}
              widths={[420, 640]}
              sizes="(max-width: 48rem) 92vw, 340px"
              loading="lazy"
            />
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .proof__platforms {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-6);
    margin-block: var(--space-6);
    padding-block: var(--space-4);
    border-block: 1px dashed var(--ez-border);
  }

  .proof__platform {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .proof__platform img {
    width: auto;
    display: block;
  }

  .proof__rating {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--ez-charcoal);
    white-space: nowrap;
  }

  .proof__platform-line {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .proof__total {
    margin: var(--space-4) 0 0;
    font-family: var(--font-display);
    font-weight: 650;
    font-size: var(--text-sm);
    color: var(--ez-charcoal);
  }

  .proof__work {
    list-style: none;
    padding: 0;
    margin: var(--space-6) 0 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: var(--space-4);
  }

  .proof__work img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-md);
  }
</style>
