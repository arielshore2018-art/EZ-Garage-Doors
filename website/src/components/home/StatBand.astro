---
/**
 * Orange stat band — the brand's loudest moment on the page.
 * Big Barlow Condensed numerals on the Primary Orange field.
 * Numbers come from STATS only (owner-supplied, verified register).
 */
import { STATS, APPROVED_CLAIMS } from "../../config/business";

const stats = [
  { value: STATS.repairs, label: "garage doors repaired" },
  { value: STATS.springRepairs, label: "springs replaced" },
  { value: STATS.openerServices, label: "openers serviced" },
  { value: STATS.fiveStarReviews, label: "5-star reviews" },
];
---

<section class="stat-band section--orange" aria-label="Track record">
  <div class="wrap stat-band__inner">
    <p class="stat-band__intro">
      {APPROVED_CLAIMS.years.replace(" in Business", "")} of doors up and down
      central Connecticut:
    </p>
    <dl class="stat-band__grid">
      {
        stats.map((s) => (
          <div class="stat-band__item">
            <dd class="display-num">{s.value}</dd>
            <dt>{s.label}</dt>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .stat-band {
    padding-block: clamp(2.5rem, 5vw, 4.5rem);
  }

  .stat-band__intro {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-lg);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ez-white);
    margin-bottom: var(--space-5);
  }

  .stat-band__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-5);
    margin: 0;
  }

  .stat-band__item {
    border-left: var(--track-stroke) solid var(--ez-white);
    padding-left: var(--space-3);
    display: grid;
  }

  .stat-band__item dd {
    margin: 0;
    font-size: var(--text-mega);
    line-height: 0.95;
    color: var(--ez-white);
  }

  .stat-band__item dt {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--ez-ink);
    margin-top: var(--space-1);
  }

  @media (max-width: 56rem) {
    .stat-band__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-4);
    }
  }
</style>
