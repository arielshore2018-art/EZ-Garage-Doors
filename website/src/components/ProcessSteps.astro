---
/**
 * "What happens when you call" — numbered steps hanging off a
 * horizontal EZ Track rail (the process-rail use of the signature).
 * Vertical rail on mobile.
 */
interface Step {
  title: string;
  detail: string;
}

interface Props {
  steps?: Step[];
  heading?: string;
  eyebrow?: string;
}

const {
  heading = "What happens when you call",
  eyebrow = "The process",
  steps = [
    {
      title: "Describe the issue",
      detail: "Tell us what the door is doing — stuck, loud bang, won't close, opener dead.",
    },
    {
      title: "Send a photo if useful",
      detail: "A quick photo of the door, spring, or opener often speeds up the diagnosis.",
    },
    {
      title: "Get your arrival window",
      detail: "We confirm the appointment and the time window before anyone drives out.",
    },
    {
      title: "Written quote before work begins",
      detail: "You see the price in writing and approve it first. Then we do the repair.",
    },
  ],
} = Astro.props;

import SectionHeading from "./SectionHeading.astro";
---

<section class="section section--alt" aria-labelledby="process-heading">
  <div class="wrap">
    <SectionHeading eyebrow={eyebrow} title={heading} />
    <ol class="steps">
      {
        steps.map((step, i) => (
          <li class="steps__item">
            <span class="steps__num display-num" aria-hidden="true">
              {String(i + 1).padStart(2, "0")}
            </span>
            <h3 class="steps__title">{step.title}</h3>
            <p class="steps__detail">{step.detail}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .steps {
    list-style: none;
    padding: calc(var(--track-stroke) + var(--track-gap) + var(--track-ghost) + 1rem) 0 0;
    margin: var(--space-6) 0 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-4);
    position: relative;
  }

  /* the horizontal track the steps hang from */
  .steps::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: var(--track-stroke);
    background: var(--ez-orange);
  }

  .steps::after {
    content: "";
    position: absolute;
    top: calc(var(--track-stroke) + var(--track-gap));
    left: 0;
    right: 0;
    height: var(--track-ghost);
    background: var(--ez-line);
  }

  .steps__item {
    background: var(--ez-white);
    border: 1px solid var(--ez-line);
    padding: var(--space-5);
    position: relative;
  }

  /* hanger connecting each step to the rail */
  .steps__item::before {
    content: "";
    position: absolute;
    top: calc(-1rem - var(--track-gap) - var(--track-ghost));
    left: var(--space-5);
    width: 3px;
    height: calc(1rem + var(--track-gap) + var(--track-ghost));
    background: var(--ez-orange);
  }

  .steps__num {
    font-size: var(--text-2xl);
    line-height: 1;
    color: var(--ez-orange);
    display: block;
    margin-bottom: var(--space-2);
  }

  .steps__title {
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
  }

  .steps__detail {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (max-width: 56rem) {
    .steps {
      grid-template-columns: 1fr;
      padding: 0 0 0 calc(var(--track-stroke) + var(--track-gap) + var(--track-ghost) + 1rem);
    }

    /* rail rotates vertical on mobile */
    .steps::before {
      top: 0;
      bottom: 0;
      left: 0;
      right: auto;
      width: var(--track-stroke);
      height: auto;
    }

    .steps::after {
      top: 0;
      bottom: 0;
      left: calc(var(--track-stroke) + var(--track-gap));
      right: auto;
      width: var(--track-ghost);
      height: auto;
    }

    .steps__item::before {
      top: 1.4rem;
      left: calc(-1rem - var(--track-gap) - var(--track-ghost));
      width: calc(1rem + var(--track-gap) + var(--track-ghost));
      height: 3px;
    }
  }
</style>
