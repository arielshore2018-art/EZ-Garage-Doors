---
/**
 * Text-only brand chips — the safe fallback chosen because logo usage
 * rights are unverified. Wording is strictly "brands we service":
 * never "authorized dealer" / "official partner" unless the owner
 * confirms a real authorization.
 */
import { BRANDS_SERVICED } from "../config/business";
import SectionHeading from "./SectionHeading.astro";

interface Props {
  heading?: string;
  brands?: readonly string[];
}

const { heading = "Garage door & opener brands we work with", brands = BRANDS_SERVICED } = Astro.props;
---

<section class="section section--alt" aria-labelledby="brands-heading">
  <div class="wrap">
    <SectionHeading eyebrow="Brands we service" title={heading} />
    <p class="muted brands__disclaimer">
      We repair and service these brands. Brand names belong to their owners — listing them
      here means we work on them, not that we are an authorized dealer.
    </p>
    <ul class="brands">
      {brands.map((brand) => <li class="brands__chip">{brand}</li>)}
    </ul>
  </div>
</section>

<style>
  .brands__disclaimer {
    font-size: var(--text-sm);
    max-width: 44rem;
    margin-bottom: var(--space-5);
  }

  .brands {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .brands__chip {
    font-family: var(--font-display);
    font-weight: 650;
    font-size: var(--text-sm);
    color: var(--ez-charcoal);
    background: #fff;
    border: 1px solid var(--ez-border);
    border-radius: 999px;
    padding: 0.45rem 1rem;
  }
</style>
