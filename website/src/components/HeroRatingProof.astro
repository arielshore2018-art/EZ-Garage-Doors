---
/**
 * Static visual rating proof: five filled SVG stars, rating text,
 * review volume, compact Google/Yelp/Angi logos. Never animated.
 *
 * Numbers come from owner-supplied review data
 * (verify-against-live-profiles-before-launch).
 */
import { Image } from "astro:assets";
import { reviewPlatformLogos } from "../config/brand-logos";
import { STATS } from "../config/business";

interface Props {
  /** Wrap in a full-width band (for placement between page sections). */
  band?: boolean;
  /** "dark" renders white text + a light backdrop chip behind platform logos. */
  tone?: "light" | "dark";
}

const { band = false, tone = "light" } = Astro.props;

const platforms = reviewPlatformLogos.filter((l) => ["google", "yelp", "angi"].includes(l.id));

const dims = (img: { width: number; height: number }, h: number) => ({
  height: h,
  width: Math.round(img.width * (h / img.height)),
});

const STAR_PATH =
  "M12 1.8l3.1 6.3 6.9 1-5 4.9 1.2 6.9L12 17.6 5.8 20.9 7 14 2 9.1l6.9-1z";
---

<div class:list={[{ "rating-band": band }]}>
  <div class:list={["rating", { "wrap": band, "rating--dark": tone === "dark" }]} role="img" aria-label={`Rated 4.9 out of 5 based on more than 850 reviews`}>
    <span class="rating__stars" aria-hidden="true">
      {
        [0, 1, 2, 3, 4].map(() => (
          <svg width="21" height="21" viewBox="0 0 24 24" fill="#f0a828" stroke="#d99417" stroke-width="0.8">
            <path d={STAR_PATH} />
          </svg>
        ))
      }
    </span>
    <span class="rating__score" aria-hidden="true">4.9 average</span>
    <span class="rating__count" aria-hidden="true">{STATS.fiveStarReviews} five-star reviews across</span>
    <span class="rating__platforms" aria-hidden="true">
      {
        platforms.map((p) => {
          const d = dims(p.src, 18);
          return <Image src={p.src} alt="" width={d.width} height={d.height} loading="eager" />;
        })
      }
    </span>
  </div>
</div>

<style>
  .rating-band {
    background: #fff;
    border-block: 1px solid var(--ez-border);
    padding-block: var(--space-3);
  }

  .rating {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }

  .rating__stars {
    display: inline-flex;
    gap: 4px;
    line-height: 0;
  }

  .rating__score {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-base);
    color: var(--ez-charcoal);
  }

  .rating__count {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .rating__platforms {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
  }

  .rating__platforms :global(img) {
    width: auto;
    display: block;
  }

  @media (min-width: 62rem) {
    .rating__stars svg {
      width: 23px;
      height: 23px;
    }
  }

  /* Dark tone: white text over the hero gradient; platform logos keep
     their brand colors on a compact light backdrop. */
  .rating--dark .rating__score {
    color: #fff;
  }

  .rating--dark .rating__count {
    color: #cfd6de;
  }

  .rating--dark .rating__platforms {
    background: rgb(255 255 255 / 0.94);
    border-radius: var(--radius-sm);
    padding: 0.3rem 0.6rem;
  }
</style>
