---
/**
 * The core anti-bait-and-switch trust module: specific operational
 * promises, not adjectives.
 */
import SectionHeading from "./SectionHeading.astro";
import { APPROVED_CLAIMS } from "../config/business";

interface Props {
  heading?: string;
}

const { heading = "Why homeowners call EZ Garage Doors" } = Astro.props;

const promises = [
  {
    title: "Written quote before work",
    detail: "You see the price in writing and approve it before any repair or installation starts.",
  },
  {
    title: "No bait pricing",
    detail: "No $29 teaser offers that triple at the door. The quote is the price.",
  },
  {
    title: "Actually local",
    detail: `A ${"Connecticut"} garage door company — not a national call center reselling your job.`,
  },
  {
    title: "Repair and installation expertise",
    detail: "Springs, cables, openers, tracks, and full door installations — one team for both.",
  },
  {
    title: "Clean, professional workmanship",
    detail: "Old parts and packaging leave with us. The garage is left the way we found it.",
  },
  {
    title: APPROVED_CLAIMS.years,
    detail: APPROVED_CLAIMS.reviews + ".",
  },
];
---

<section class="section" aria-labelledby="promise-heading">
  <div class="wrap">
    <SectionHeading eyebrow="Straight answers" title={heading} />
    <ul class="promises">
      {
        promises.map((p) => (
          <li class="promises__item">
            <h3>
              <span class="speed-tick" aria-hidden="true" />
              {p.title}
            </h3>
            <p>{p.detail}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .promises {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: var(--space-5) var(--space-6);
  }

  .promises__item h3 {
    display: flex;
    align-items: center;
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .promises__item p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
    padding-left: calc(1.1rem + var(--space-2));
  }
</style>
