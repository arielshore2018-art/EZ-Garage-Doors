---
/**
 * JSON-LD structured data. LocalBusiness on every page; optional
 * Service and FAQPage blocks per page.
 *
 * Deliberately absent until verified (do not add without live proof):
 * - telephone (no final number yet)
 * - aggregateRating / Review markup (counts unverified; third-party
 *   Google ratings must not be marked up as on-site reviews)
 * - license numbers, priceRange
 */
import { BUSINESS } from "../config/business";
import { cities } from "../config/cities";

interface Props {
  service?: {
    name: string;
    description: string;
    url: string;
  };
  faqs?: { question: string; answer: string }[];
}

const { service, faqs } = Astro.props;

const localBusiness = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  name: BUSINESS.name,
  url: BUSINESS.SITE_URL,
  image: new URL("/og-default.png", BUSINESS.SITE_URL).href,
  slogan: BUSINESS.tagline,
  areaServed: cities.map((c) => ({
    "@type": "City",
    name: `${c.name}, ${BUSINESS.stateAbbr}`,
  })),
  knowsAbout: [
    "garage door repair",
    "garage door spring replacement",
    "garage door opener repair",
    "garage door installation",
  ],
};

const serviceSchema = service
  ? {
      "@context": "https://schema.org",
      "@type": "Service",
      serviceType: service.name,
      description: service.description,
      url: new URL(service.url, BUSINESS.SITE_URL).href,
      provider: {
        "@type": "HomeAndConstructionBusiness",
        name: BUSINESS.name,
        url: BUSINESS.SITE_URL,
      },
      areaServed: { "@type": "State", name: BUSINESS.state },
    }
  : null;

const faqSchema =
  faqs && faqs.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqs.map((f) => ({
          "@type": "Question",
          name: f.question,
          acceptedAnswer: { "@type": "Answer", text: f.answer },
        })),
      }
    : null;

/* Breadcrumbs: Home → Service, derived from the service prop so every
   service page gets a BreadcrumbList without per-page wiring. */
const breadcrumbSchema = service
  ? {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: BUSINESS.SITE_URL,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: service.name,
          item: new URL(service.url, BUSINESS.SITE_URL).href,
        },
      ],
    }
  : null;
---

<script type="application/ld+json" set:html={JSON.stringify(localBusiness)} />
{serviceSchema && <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />}
{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
{breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
