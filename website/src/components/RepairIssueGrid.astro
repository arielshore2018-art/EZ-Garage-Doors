---
/**
 * Symptom/issue grid — meets urgent visitors at their actual problem.
 * Cards become links when an href is provided (routing to the
 * specialty page that solves that symptom).
 */
import SectionHeading from "./SectionHeading.astro";

interface Issue {
  symptom: string;
  meaning: string;
  href?: string;
}

interface Props {
  heading?: string;
  eyebrow?: string;
  issues: Issue[];
  alt?: boolean;
}

const { heading = "What is your door doing?", eyebrow = "Common problems", issues, alt = false } = Astro.props;
---

<section class:list={["section", { "section--alt": alt }]} aria-labelledby="issues-heading">
  <div class="wrap">
    <SectionHeading eyebrow={eyebrow} title={heading} />
    <ul class="issues">
      {
        issues.map((issue) => (
          <li class:list={["issues__card", { "issues__card--link": !!issue.href }]}>
            {issue.href ? (
              <a href={issue.href}>
                <h3>{issue.symptom}</h3>
                <p>{issue.meaning}</p>
                <span class="issues__go" aria-hidden="true">→</span>
              </a>
            ) : (
              <>
                <h3>{issue.symptom}</h3>
                <p>{issue.meaning}</p>
              </>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .issues {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: var(--space-4);
  }

  .issues__card {
    background: var(--ez-white);
    border: 1px solid var(--ez-line);
    border-top: 3px solid var(--ez-orange);
    padding: var(--space-5);
  }

  .issues__card--link {
    padding: 0;
  }

  .issues__card--link a {
    display: block;
    padding: var(--space-5);
    height: 100%;
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: background-color 140ms ease;
  }

  .issues__card--link a:hover {
    background: var(--ez-orange-pale);
  }

  .issues__go {
    position: absolute;
    right: var(--space-4);
    bottom: var(--space-3);
    color: var(--ez-orange);
    font-size: var(--text-lg);
  }

  .issues__card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .issues__card p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
