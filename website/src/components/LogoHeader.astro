---
/**
 * Full-site header: logo, primary nav, call CTA.
 * Mobile menu is a no-JS <details> disclosure — no menu library.
 */
import { Image } from "astro:assets";
import logo from "../assets/brand/ez-logo-primary-horizontal.svg";
import CallButton from "./CallButton.astro";

const nav = [
  { href: "/garage-door-repair/", label: "Repair" },
  { href: "/broken-spring-repair/", label: "Springs" },
  { href: "/garage-door-opener-repair/", label: "Openers" },
  { href: "/garage-door-installation/", label: "Installation" },
  { href: "/commercial-garage-door-repair/", label: "Commercial" },
  { href: "/service-areas/", label: "Service Areas" },
  { href: "/about/", label: "About" },
];

const current = Astro.url.pathname;
---

<header class="site-header">
  <div class="wrap site-header__inner">
    <a href="/" class="site-header__logo" aria-label="EZ Garage Doors — home">
      <Image src={logo} alt="EZ Garage Doors — Fast. Reliable. Local." width={210} loading="eager" />
    </a>

    <nav class="site-header__nav" aria-label="Main">
      <ul>
        {
          nav.map((item) => (
            <li>
              <a href={item.href} aria-current={current === item.href ? "page" : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="site-header__cta">
      <CallButton label="Call for Repair" />
    </div>

    <details class="site-header__mobile">
      <summary aria-label="Open menu">
        <span class="site-header__burger" aria-hidden="true"></span>
        <span class="visually-hidden">Menu</span>
      </summary>
      <nav aria-label="Main mobile">
        <ul>
          {
            nav.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))
          }
          <li><a href="/contact/">Get a Written Estimate</a></li>
        </ul>
      </nav>
    </details>
  </div>
</header>

<style>
  .site-header {
    background: #fff;
    border-bottom: 1px solid var(--ez-border);
    position: relative;
    z-index: 20;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    min-height: 4.25rem;
  }

  .site-header__logo img {
    width: clamp(150px, 17vw, 225px);
    height: auto;
  }

  .site-header__nav {
    margin-left: auto;
  }

  .site-header__nav ul {
    display: flex;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-header__nav a {
    font-family: var(--font-display);
    font-weight: 650;
    font-size: var(--text-sm);
    text-decoration: none;
    color: var(--ez-charcoal);
    padding: 0.4rem 0.15rem;
    border-bottom: 3px solid transparent;
    white-space: nowrap;
  }

  .site-header__cta :global(.btn) {
    white-space: nowrap;
    padding-inline: 1.1rem;
  }

  .site-header__nav a:hover,
  .site-header__nav a[aria-current="page"] {
    border-bottom-color: var(--ez-orange);
  }

  .site-header__mobile {
    display: none;
    margin-left: auto;
  }

  .site-header__mobile summary {
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    list-style: none;
    border: 2px solid var(--ez-charcoal);
    border-radius: var(--radius-md);
    width: 44px;
    height: 44px;
    padding: 0;
  }

  .site-header__mobile summary::-webkit-details-marker {
    display: none;
  }

  .site-header__burger,
  .site-header__burger::before,
  .site-header__burger::after {
    display: block;
    width: 18px;
    height: 2px;
    background: currentColor;
    position: relative;
  }

  .site-header__burger::before,
  .site-header__burger::after {
    content: "";
    position: absolute;
    left: 0;
  }

  .site-header__burger::before {
    top: -5px;
  }

  .site-header__burger::after {
    top: 5px;
  }

  .site-header__mobile nav {
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    background: #fff;
    border-bottom: 1px solid var(--ez-border);
    box-shadow: var(--shadow-card);
  }

  .site-header__mobile nav ul {
    list-style: none;
    margin: 0;
    padding: var(--space-3) 0;
  }

  .site-header__mobile nav a {
    display: block;
    padding: 0.8rem clamp(1rem, 4vw, 2rem);
    font-family: var(--font-display);
    font-weight: 650;
    text-decoration: none;
    color: var(--ez-charcoal);
  }

  .site-header__mobile nav a:hover {
    background: var(--ez-orange-tint);
  }

  @media (max-width: 62rem) {
    .site-header__nav,
    .site-header__cta {
      display: none;
    }

    .site-header__mobile {
      display: block;
    }
  }
</style>
