---
/**
 * "Text a photo" CTA. While no phone/SMS number exists, it routes to
 * the contact form's photo upload — same promise, working path.
 * When PRIMARY_PHONE_TEL is set, this becomes an sms: link automatically.
 */
import { BUSINESS, hasPhone } from "../config/business";

interface Props {
  label?: string;
  variant?: "call" | "outline" | "inverse-outline";
}

const { label = "Text a Photo of Your Door", variant = "outline" } = Astro.props;

const href = hasPhone() ? `sms:${BUSINESS.PRIMARY_PHONE_TEL}` : "/contact/#request";
---

<div class="photo-cta">
  <a href={href} class={`btn btn--${variant}`} data-track="photo_cta_click">
    <svg
      aria-hidden="true"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"></path>
      <circle cx="12" cy="13" r="3"></circle>
    </svg>
    <span>{label}</span>
  </a>
  <p class="cta-note">Send a photo and we'll tell you the next step.</p>
</div>

<style>
  .photo-cta {
    display: inline-block;
  }
</style>
