---
/**
 * Central phone CTA. Every "call" button on the site goes through this
 * component so the final phone number is inserted in exactly one place.
 *
 * TODO: Replace PRIMARY_PHONE and PRIMARY_PHONE_TEL in src/config/business.ts
 * before launch. Until then the button links to the estimate form instead of
 * a dead tel: link — no fake number is ever rendered.
 */
import { BUSINESS, hasPhone } from "../config/business";

interface Props {
  label?: string;
  size?: "md" | "lg";
  variant?: "call" | "outline" | "inverse-outline";
  /** Where the button goes while no phone number exists. */
  fallbackHref?: string;
  track?: string;
  class?: string;
}

const {
  label = "Call EZ Garage Doors",
  size = "md",
  variant = "call",
  fallbackHref = "/contact/#request",
  track = "call_click",
  class: className = "",
} = Astro.props;

const href = hasPhone() ? `tel:${BUSINESS.PRIMARY_PHONE_TEL}` : fallbackHref;
const classes = ["btn", `btn--${variant}`, size === "lg" ? "btn--lg" : "", className]
  .filter(Boolean)
  .join(" ");
---

<a href={href} class={classes} data-track={track}>
  <svg
    aria-hidden="true"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path
      d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
    ></path>
  </svg>
  <span>{label}</span>
</a>
