---
/**
 * Service-page hero — light editorial split, not a dark overlay.
 * Type panel on warm paper (ink text, instant legibility for a
 * stressed visitor), real photo with an EZ Track corner bracket.
 * Each service page passes a UNIQUE imageId (enforced by review).
 */
import { Image } from "astro:assets";
import CallButton from "./CallButton.astro";
import { img } from "../config/site-images";
import { reviews } from "../config/reviews";

interface Props {
  imageId: string;
  eyebrow: string;
  heading: string;
  sub: string;
  callLabel?: string;
  callTrack?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  /** Optional alert line (e.g. spring safety warning). */
  alert?: string;
  micro?: string;
  showRating?: boolean;
  /** "estimate" renders the primary CTA as an estimate link instead of a call button. */
  primaryMode?: "call" | "estimate";
  primaryHref?: string;
}

const {
  imageId,
  eyebrow,
  heading,
  sub,
  callLabel = "Call for Repair",
  callTrack = "hero_call_click",
  secondaryLabel = "Send a Photo",
  secondaryHref = "/contact/#request",
  alert,
  micro = "Written quote before work begins.",
  showRating = true,
  primaryMode = "call",
  primaryHref = "#request",
} = Astro.props;

const image = img(imageId);
---

<section class="shero">
  <div class="shero__grid">
    <div class="shero__copy">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{heading}</h1>
      <span class="track-run" aria-hidden="true"></span>
      <p class="shero__sub">{sub}</p>
      {alert && <p class="shero__alert" role="alert"><strong>Safety first:</strong> {alert}</p>}
      <div class="shero__actions">
        {
          primaryMode === "call" ? (
            <CallButton label={callLabel} size="lg" track={callTrack} />
          ) : (
            <a href={primaryHref} class="btn btn--call btn--lg" data-track={callTrack}>
              {callLabel}
            </a>
          )
        }
        <a href={secondaryHref} class="shero__secondary" data-track="photo_cta_click">
          {secondaryLabel}
        </a>
      </div>
      <p class="shero__micro muted">{micro}</p>
      {
        showRating && (
          <p class="shero__rating">
            <span class="shero__stars" aria-hidden="true">★★★★★</span>
            <span>
              {reviews.google.rating} on Google · 850+ five-star reviews across platforms
            </span>
          </p>
        )
      }
    </div>

    <div class="shero__media track-frame">
      <Image
        src={image.src}
        alt={image.alt}
        widths={[480, 800, 1200, 1600]}
        sizes="(max-width: 56rem) 100vw, 55vw"
        loading="eager"
        fetchpriority="high"
        class="shero__img"
        style={`object-position: ${image.focalPointDesktop ?? "center"};`}
      />
    </div>
  </div>
</section>

<style>
  .shero {
    background: var(--ez-paper);
    border-bottom: 1px solid var(--ez-line);
    overflow: hidden;
  }

  .shero__grid {
    display: grid;
    grid-template-columns: minmax(0, 6fr) minmax(0, 6fr);
    gap: clamp(1.5rem, 4vw, 3.5rem);
    max-width: var(--content-max);
    margin-inline: auto;
    padding: clamp(2rem, 5vw, 4rem) clamp(1rem, 4vw, 2rem);
    align-items: center;
  }

  .shero__copy h1 {
    font-size: clamp(2.3rem, 1.6rem + 3.2vw, 4rem);
    margin-top: var(--space-3);
  }

  .shero__sub {
    margin-top: var(--space-4);
    font-size: var(--text-lg);
    max-width: 32rem;
  }

  .shero__alert {
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background: var(--ez-orange-pale);
    border-left: var(--track-stroke) solid var(--ez-orange);
    max-width: 32rem;
    color: var(--ez-ink);
    font-size: var(--text-sm);
  }

  .shero__actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-5);
  }

  .shero__actions :global(.btn) {
    white-space: nowrap;
  }

  .shero__secondary {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ez-ink);
    text-decoration-color: var(--ez-orange);
    text-decoration-thickness: 2px;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
  }

  .shero__secondary:hover {
    color: var(--ez-orange-deep);
  }

  .shero__micro {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
  }

  .shero__rating {
    margin-top: var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    border-top: 1px solid var(--ez-line);
    padding-top: var(--space-3);
    max-width: 32rem;
  }

  .shero__stars {
    color: var(--ez-orange);
    letter-spacing: 0.1em;
  }

  .shero__media {
    align-self: stretch;
    min-height: clamp(16rem, 36vw, 30rem);
    position: relative;
  }

  .shero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 56rem) {
    .shero__grid {
      grid-template-columns: 1fr;
      padding-top: var(--space-5);
    }

    .shero__copy h1 {
      font-size: clamp(2.1rem, 1.5rem + 4vw, 2.9rem);
    }

    .shero__sub {
      font-size: var(--text-base);
    }

    .shero__actions :global(.btn) {
      flex: 1 1 100%;
      justify-content: center;
    }

    .shero__media {
      min-height: 15rem;
      order: 2;
    }

    /* bracket sits inside the viewport on mobile */
    .shero__media.track-frame::before {
      top: 0;
      left: 0;
    }
  }
</style>
